# Required — from https://aistudio.google.com (Get API key -> Create API key)
GEMINI_API_KEY=

# Optional but recommended — from https://www.semanticscholar.org/product/api
# Without this you share the unauthenticated rate pool, which is fine for a
# single-paper run but less predictable under load.
SEMANTIC_SCHOLAR_API_KEY=

# Optional overrides — see README.md "Model names may need adjusting"
# gemini-2.5-flash was deprecated for new API keys in 2026; gemini-3.5-flash
# is the current free-tier default below. Override here if either 404s for you.
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Set to 1 to run the whole pipeline against canned responses instead of real
# Gemini calls — use this while debugging wiring/logic so you don't spend real
# free-tier quota on runs that aren't about getting a real analysis.
# MOCK_LLM=1
